# Dev-only image for the TCA Timer judge SPA.
#
# Mirrors `server/Dockerfile.dev`: install deps once, bind-mount the
# source tree at runtime so vite's HMR sees host edits.
#
# NOTE: this Dockerfile expects the build context to be the repo root
# (see `docker-compose.yml`), not the `spa/` directory. We need both
# `spa/` and `shared/` because the SPA's package.json declares
# `@tca-timer/shared` as `file:../shared`, and `npm ci` resolves that
# link relative to the SPA's working directory.

FROM node:22-alpine

RUN apk add --no-cache git bash

# Stage the shared package at /shared so that `file:../shared` from
# /app resolves correctly during `npm ci`. Only the files needed by the
# SPA at runtime are copied — `package.json` plus the TypeScript
# sources that vite will transpile on the fly.
#
# We also `npm ci` inside /shared so that the package's own runtime
# deps (notably `zod`, used by `@tca-timer/shared/api`) are present
# when vite resolves them. Without this, the dev server's
# import-analysis pass fails with `Failed to resolve import "zod"
# from /shared/src/api/index.ts`. The compose file additionally
# mounts a named volume at /shared/node_modules so the host-side
# `./shared:/shared` bind mount doesn't clobber what we install here.
WORKDIR /shared
COPY shared/package.json shared/package-lock.json ./
RUN npm ci --no-audit --no-fund
COPY shared/src ./src

WORKDIR /app

COPY spa/package.json spa/package-lock.json ./
RUN npm ci --no-audit --no-fund

COPY spa/. .

EXPOSE 5173

# `--host` makes vite bind 0.0.0.0 so the dev server is reachable from
# the host (and other devices on the LAN — handy for PWA install
# testing on a phone).
CMD ["npm", "run", "dev", "--", "--host", "--port", "5173"]
