{
  "name": "tca-timer-server",
  "version": "0.0.1",
  "private": true,
  "description": "TCA Timer backend — Fastify + ws + Postgres (scaffolding).",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --test-force-exit --import tsx ./test/*.test.ts",
    "migrate": "tsx src/db/migrate.ts",
    "seed:dev": "tsx src/db/seed-dev.ts"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1039.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/formbody": "^7.4.0",
    "@fastify/websocket": "^10.0.1",
    "@tca-timer/shared": "file:../shared",
    "bcrypt": "^6.0.0",
    "fastify": "^4.28.1",
    "jose": "^6.2.3",
    "node-pg-migrate": "^8.0.4",
    "openid-client": "^5.7.1",
    "pg": "^8.20.0",
    "sns-validator": "^0.3.5",
    "twilio": "^6.0.0",
    "ws": "^8.18.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.20.0",
    "@types/sns-validator": "^0.3.3",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
