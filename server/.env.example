# Server (§11.1)
PORT=3000
DATABASE_URL=postgres://user:pass@localhost:5432/tca_timer

# Auth — server-mediated OIDC (§8.1, replaces Cloudflare Access JWT).
# Single provider per deployment. Cloudflare Access (with an OIDC SaaS
# app), Google, Microsoft, Okta, Auth0, etc. all work behind these
# same env vars.
OIDC_ISSUER=                            # e.g. https://<team>.cloudflareaccess.com or https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=                      # absolute URL of /api/auth/callback as the user agent sees it
OIDC_SCOPES=openid profile email
OIDC_GROUPS_CLAIM=groups                # ID-token claim that carries the user's groups; optional
OIDC_ADMIN_EMAILS=                      # comma-separated allowlist promoted to `judges-admin`; optional
OIDC_ALLOW_ALL_ROOMS=                   # `1` to make every authenticated user admin (single-tenant convenience)
SESSION_SECRET=                         # ≥32 chars; used to encrypt+sign the session cookie

# Dev only: skip OIDC entirely and run requests as a synthetic admin
# judge. Hard-disabled when NODE_ENV=production.
# DEV_AUTH_BYPASS=1

PUBLIC_ORIGIN=http://localhost:5173

# Twilio SMS (§7.4.2) — optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS SES (§7.4.3) — optional
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_FROM_ADDRESS=
SES_CONFIGURATION_SET=
SES_SNS_TOPIC_ARN=
